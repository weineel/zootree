#!/usr/bin/env bash
set -euo pipefail

# 如果没有 staged 的 .rs 文件，直接退出
if git diff --cached --quiet --diff-filter=ACMR -- '*.rs'; then
    exit 0
fi

# 若工作区有未暂存的 .rs 改动，先 stash --keep-index 保护它们
stashed=0
if ! git diff --quiet -- '*.rs'; then
    git stash push --keep-index --quiet --message "pre-commit-fmt"
    stashed=1
fi

# 无论后续成功与否，最终都尝试恢复 stash；pop 失败也不影响 hook 退出码
trap '
if [ "$stashed" = 1 ]; then
    git stash pop --quiet || echo "pre-commit: stash pop 失败，请手动运行 git stash pop 解决冲突" >&2
fi
' EXIT

# 只对 staged 的 .rs 文件跑 rustfmt
git diff --cached --name-only --diff-filter=ACMR -z -- '*.rs' \
    | xargs -0 rustfmt --edition 2021

# 把格式化结果加回本次提交
git diff --cached --name-only --diff-filter=ACMR -z -- '*.rs' \
    | xargs -0 git add --
