#!/usr/bin/env bash
set -euo pipefail

# 收集 staged 的 .rs 文件（NUL 分隔，兼容特殊字符）
staged_files=()
while IFS= read -r -d '' file; do
    staged_files+=("$file")
done < <(git diff --cached --name-only --diff-filter=ACMR -z -- '*.rs')

[ "${#staged_files[@]}" -eq 0 ] && exit 0

# 临时目录存放格式化中间产物；rustfmt 失败时 set -e 中止，index 未动
tmpdir=$(mktemp -d)
trap 'rm -rf "$tmpdir"' EXIT

update_modes=()
update_hashes=()
update_paths=()
sync_paths=()
sync_tmpfiles=()

# 第一阶段：从 index 取 blob → rustfmt → 写新 object，收集待应用的变更
for ((i = 0; i < ${#staged_files[@]}; i++)); do
    file="${staged_files[$i]}"
    entry=$(git ls-files -s -- "$file")
    [ -z "$entry" ] && continue

    mode=$(awk '{print $1}' <<< "$entry")
    old_hash=$(awk '{print $2}' <<< "$entry")

    tmpfile="$tmpdir/$i.rs"
    git cat-file blob "$old_hash" > "$tmpfile"
    rustfmt --edition 2021 "$tmpfile"

    new_hash=$(git hash-object -w -- "$tmpfile")
    [ "$new_hash" = "$old_hash" ] && continue

    update_modes+=("$mode")
    update_hashes+=("$new_hash")
    update_paths+=("$file")

    # 工作区与 index 一致（无 unstaged 改动）时，格式化结果也同步到工作区
    if git diff --quiet -- "$file"; then
        sync_paths+=("$file")
        sync_tmpfiles+=("$tmpfile")
    fi
done

# 第二阶段：批量更新 index（所有文件都已通过 rustfmt，原子性更好）
for ((i = 0; i < ${#update_paths[@]}; i++)); do
    git update-index --cacheinfo \
        "${update_modes[$i]}" "${update_hashes[$i]}" "${update_paths[$i]}"
done

# 第三阶段：同步工作区（仅对原本无 unstaged 改动的文件）
for ((i = 0; i < ${#sync_paths[@]}; i++)); do
    cp -- "${sync_tmpfiles[$i]}" "${sync_paths[$i]}"
done
