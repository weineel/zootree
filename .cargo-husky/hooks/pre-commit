#!/usr/bin/env bash
set -euo pipefail

# 没有 staged .rs 文件时跳过（纯文档/配置 commit 不触发 cargo 工具链）
if git diff --cached --quiet --diff-filter=ACMR -- '*.rs'; then
    exit 0
fi

# 全量格式化
cargo fmt --all

# 静态校验（确保格式化后仍能编译）
cargo check --all-targets --quiet

# 把所有 .rs 改动（包括 cargo fmt 产生的）一并纳入本次 commit
git add -u -- '*.rs'
